# PostgreSQL (shared credentials for all DBs)
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password

# ms-events database
EVENTS_DB_NAME=your_events_db_name
EVENTS_DB_PORT=5433
EVENTS_DATASOURCE_URL=jdbc:postgresql://db-events:5432/your_events_db_name
EVENTS_DATASOURCE_USERNAME=your_db_username
EVENTS_DATASOURCE_PASSWORD=your_db_password

# ms-events app
EVENTS_PORT=8081

# ms-ticketing database
TICKETING_DB_NAME=your_ticketing_db_name
TICKETING_DB_PORT=5434
TICKETING_DATASOURCE_URL=jdbc:postgresql://db-ticketing:5432/your_ticketing_db_name
TICKETING_DATASOURCE_USERNAME=your_db_username
TICKETING_DATASOURCE_PASSWORD=your_db_password

# ms-ticketing app
TICKETING_PORT=8082

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
