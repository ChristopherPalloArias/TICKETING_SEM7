    {
      "name": "CA-01: Configuración Válida de Tiers",
      "item": [
        {
          "name": "POST - 3 Tiers válidos (VIP + General + Early Bird)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has eventId and 3 tiers', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('eventId');",
                  "    pm.expect(jsonData.tiers).to.be.an('array');",
                  "    pm.expect(jsonData.tiers.length).to.equal(3);",
                  "});",
                  "",
                  "pm.test('Tiers contienen VIP, General y Early Bird', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var tierTypes = jsonData.tiers.map(t => t.tierType);",
                  "    pm.expect(tierTypes).to.include('VIP');",
                  "    pm.expect(tierTypes).to.include('GENERAL');",
                  "    pm.expect(tierTypes).to.include('EARLY_BIRD');",
                  "});",
                  "",
                  "pm.test('Precios y cupos son correctos', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var vip = jsonData.tiers.find(t => t.tierType === 'VIP');",
                  "    var general = jsonData.tiers.find(t => t.tierType === 'GENERAL');",
                  "    var earlyBird = jsonData.tiers.find(t => t.tierType === 'EARLY_BIRD');",
                  "    ",
                  "    pm.expect(vip.price).to.equal(75.00);",
                  "    pm.expect(vip.quota).to.equal(300);",
                  "    ",
                  "    pm.expect(general.price).to.equal(50.00);",
                  "    pm.expect(general.quota).to.equal(900);",
                  "    ",
                  "    pm.expect(earlyBird.price).to.equal(30.00);",
                  "    pm.expect(earlyBird.quota).to.equal(300);",
                  "});",
                  "",
                  "pm.test('Todos los tiers tienen timestamps created_at y updated_at', function () {",
                  "    var jsonData = pm.response.json();",
                  "    jsonData.tiers.forEach(tier => {",
                  "        pm.expect(tier).to.have.property('created_at');",
                  "        pm.expect(tier).to.have.property('updated_at');",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Role",
                "value": "ADMIN"
              },
              {
                "key": "X-User-Id",
                "value": "admin-user-001"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"tierType\": \"VIP\",\n    \"price\": 75.00,\n    \"quota\": 300,\n    \"validFrom\": null,\n    \"validUntil\": null\n  },\n  {\n    \"tierType\": \"GENERAL\",\n    \"price\": 50.00,\n    \"quota\": 900,\n    \"validFrom\": null,\n    \"validUntil\": null\n  },\n  {\n    \"tierType\": \"EARLY_BIRD\",\n    \"price\": 30.00,\n    \"quota\": 300,\n    \"validFrom\": \"2026-04-01T00:00:00Z\",\n    \"validUntil\": \"2026-05-01T23:59:59Z\"\n  }\n]"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/events/{{eventId}}/tiers",
              "host": [
