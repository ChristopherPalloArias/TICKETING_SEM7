        {
          "name": "POST - Early Bird con vigencia válida (validFrom < validUntil)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Early Bird tiene validFrom < validUntil', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var earlyBird = jsonData.tiers.find(t => t.tierType === 'EARLY_BIRD');",
                  "    ",
                  "    pm.expect(earlyBird).to.exist;",
                  "    pm.expect(earlyBird.validFrom).to.equal('2026-04-01T00:00:00Z');",
                  "    pm.expect(earlyBird.validUntil).to.equal('2026-05-01T23:59:59Z');",
                  "    ",
                  "    var from = new Date(earlyBird.validFrom);",
                  "    var until = new Date(earlyBird.validUntil);",
                  "    pm.expect(from < until).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
