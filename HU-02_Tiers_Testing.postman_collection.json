    {
      "name": "Setup - HU-01: Crear Evento",
      "item": [
        {
          "name": "POST - Crear Sala (Room)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response has id and maxCapacity', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('maxCapacity');",
                  "    pm.expect(jsonData.maxCapacity).to.equal(1500);",
                  "    pm.expect(jsonData).to.have.property('name');",
                  "    pm.collectionVariables.set('roomId', jsonData.id);",
                  "});",
                  "",
                  "pm.test('Response has timestamps', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('created_at');",
                  "    pm.expect(jsonData).to.have.property('updated_at');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sala Principal\",\n  \"maxCapacity\": 1500\n}"
            },
